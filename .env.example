# claude-pmax-harness — environment variables
# Copy this file to .env and fill in the values. .env is gitignored.
# After editing, run `harness doctor` to verify.
# All values are placeholders — replace with your own. Do NOT commit your filled-in .env.

# === Required ===

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (the bot ignores messages from other users)
# Easiest path: run `harness setup` and it will capture this for you.
TELEGRAM_OWNER_CHAT_ID=

# === Optional ===

# Override the runtime data directory (default: ~/.claude-pmax-harness)
# HARNESS_DATA_DIR=

# Log level: error | warn | info | debug (default: info)
# HARNESS_LOG_LEVEL=info

# Path to the Claude CLI binary if not on PATH
# CLAUDE_CLI=claude

# === Google adapter (OPTIONAL — only if you enabled it in setup) ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
